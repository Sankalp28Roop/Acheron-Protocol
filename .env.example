# =============================================================================
# CloakComms — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ── Gateway (Fastify) ─────────────────────────────────────────────────────────
GATEWAY_PORT=3001
GATEWAY_HOST=0.0.0.0

# CORS: comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=cloakcomms
POSTGRES_PASSWORD=cloakcomms_secret
POSTGRES_DB=cloakcomms
DATABASE_URL=postgresql://cloakcomms:cloakcomms_secret@localhost:5432/cloakcomms

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@localhost:6379

# ── Twilio (SMS provisioning) ─────────────────────────────────────────────────
# Get these from https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# ISO country code for number search (default: US)
TWILIO_NUMBER_COUNTRY=US
# Optional: Twilio Messaging Service SID for pooled sending
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Mailgun (Email inbound routing) ──────────────────────────────────────────
# Get these from https://app.mailgun.com/
MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAILGUN_DOMAIN=mail.yourdomain.com
# The catch-all email domain for generated addresses (e.g., cloak.mail)
EMAIL_DOMAIN=cloak.mail
# Mailgun webhook signing key (for inbound webhook verification)
MAILGUN_WEBHOOK_SIGNING_KEY=your_webhook_signing_key

# ── Security ──────────────────────────────────────────────────────────────────
# Rate limiting: max requests per minute per IP on /api/v1/* routes
RATE_LIMIT_MAX=60
# Comma-separated list of blocked sender domains (messages silently dropped)
# Example: chase.com,wellsfargo.com,instagram.com
BLOCKED_SENDER_DOMAINS=

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
NEXT_PUBLIC_GATEWAY_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ── Credential Limits ─────────────────────────────────────────────────────────
# Free tier: max active credentials per session
FREE_TIER_MAX_CREDENTIALS=3
# Minimum TTL in seconds (5 minutes)
MIN_TTL_SECONDS=300
# Maximum TTL in seconds (24 hours)
MAX_TTL_SECONDS=86400
