generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  // A single user can have multiple active credentials
  credentials ActiveCredential[]

  @@map("users")
}

model ActiveCredential {
  id        String   @id @default(uuid())
  type      String   // "EMAIL" or "SMS"
  value     String   @unique
  expiresAt DateTime

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([value])
  @@index([expiresAt])

  @@map("active_credentials")
}
